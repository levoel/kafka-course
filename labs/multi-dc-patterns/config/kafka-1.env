# Дополнительные настройки Kafka DC-1 (Primary)
# Эти переменные дополняют основную конфигурацию в docker-compose.yml
# Здесь можно переопределить любые KAFKA_* параметры DC-1

# Имя лог-директории для идентификации в логах
KAFKA_LOG_RETENTION_HOURS=72

# Авто-создание топиков (в production отключить: false)
KAFKA_AUTO_CREATE_TOPICS_ENABLE=true

# Минимальный ISR для одноброкерного стенда
KAFKA_MIN_INSYNC_REPLICAS=1
