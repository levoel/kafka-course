# Дополнительные настройки Kafka DC-2 (DR Standby)
# Эти переменные дополняют основную конфигурацию в docker-compose.yml

# Retention для DC-2: короче основного (DR-кластер хранит меньше истории)
KAFKA_LOG_RETENTION_HOURS=24

# Авто-создание топиков: включено для принятия реплицированных топиков от MM2
KAFKA_AUTO_CREATE_TOPICS_ENABLE=true

# Минимальный ISR для одноброкерного DR-стенда
KAFKA_MIN_INSYNC_REPLICAS=1
